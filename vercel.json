{
  "rewrites": [
    {
      "source": "/api/openai/:path*",
      "destination": "https://api.openai.com/v1/:path*"
    },
    {
      "source": "/api/anthropic/:path*",
      "destination": "https://api.anthropic.com/v1/:path*"
    },
    {
      "source": "/api/moonshot/:path*",
      "destination": "https://api.moonshot.cn/v1/:path*"
    },
    {
      "source": "/api/deepseek/:path*",
      "destination": "https://api.deepseek.com/v1/:path*"
    },
    {
      "source": "/api/glm/:path*",
      "destination": "https://open.bigmodel.cn/api/paas/v4/:path*"
    },
    {
      "source": "/api/gemini/:path*",
      "destination": "https://generativelanguage.googleapis.com/v1beta/:path*"
    }
  ]
}
